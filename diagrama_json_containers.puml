@startuml
skinparam packageStyle rectangle
skinparam backgroundColor #FEFEFE
skinparam defaultFontName Consolas
skinparam defaultFontSize 10
skinparam rectangleBorderColor #333333
skinparam rectangleFontSize 12
skinparam rectangleFontStyle bold
hide circle
hide empty members

title "Diagrama de Contenedores JSON\nCada rectángulo = un archivo en /backend/data/\nLas flechas = referencias por ID entre archivos"
scale .7

legend right
  PK = Clave primaria
  FK = Clave foranea (ID referenciado a otro JSON)
  emb = Objeto embebido dentro del JSON del padre
  ===
  Flecha == "apunta a"
endlegend

' ============================================================
' USUARIOS
' ============================================================
rectangle "usuarios.json\n<<Usuario>>" as R_USUARIO {
  class "Usuario" as USUARIO <<entity>> {
    + id : String [PK]
    + nombre : String
    + correoElectronico : String
    + telefono : String
    + descripcionPersonal : String
    + contrasenaHash : String
    + version : int
    + estado : String
    + rol : String
    + intentosFallidos : int
    + tiempoDesbloqueoMillis : long
    + primerIntentoFallidoMillis : long
    + reportesFraudeValidados : int
    + urlFotoPerfil : String
    + promedioCalificacion : float
    + cantidadCalificaciones : int
    + esVecinoDestacado : boolean
  }
  class "Monedero" as MONEDERO <<emb>> {
    + creditosDisponibles : float
    + creditosComprometidos : float
    + creditosPorLogros : float
  }
  class "Catalogo" as CATALOGO <<emb>> {
    + completado : boolean
  }
  class "Habilidad Ofrecida []" as HAB_OFRE <<emb>> {
    + idInstancia : String [PK]
    + habilidadBase.id : String [FK]
    + precioCreditos : int
    + descripcionServicio : String
  }
  class "Necesidad Registrada []" as NEC_REG <<emb>> {
    + idInstancia : String [PK]
    + necesidadBase.id : String [FK]
    + descripcionCondiciones : String
  }
  USUARIO *-- MONEDERO
  USUARIO *-- CATALOGO
  CATALOGO *-- HAB_OFRE
  CATALOGO *-- NEC_REG
}

' ============================================================
' HABILIDADES
' ============================================================
rectangle "habilidades.json\n<<Habilidad>>" as R_HABILIDAD {
  class "Habilidad" as HABILIDAD <<entity>> {
    + id : String [PK]
    + categoria : String
  }
}

' ============================================================
' PUBLICACIONES
' ============================================================
rectangle "publicaciones.json\n<<Publicacion>>" as R_PUBLICACION {
  class "Publicacion" as PUBLICACION <<entity>> {
    + idPublicacion : String [PK]
    + idUsuario : String [FK]
    + tipoPublicacion : String
    + nombreServicio : String
    + descripcion : String
    + precioCreditos : int
    + disponible : boolean
    + idInstanciaCatalogo : String [FK]
    + version : int
  }
}

' ============================================================
' SOLICITUDES
' ============================================================
rectangle "solicitudes.json\n<<Solicitud>>" as R_SOLICITUD {
  class "Solicitud" as SOLICITUD <<entity>> {
    + idSolicitud : String [PK]
    + idPublicacion : String [FK]
    + idSolicitante : String [FK]
    + estado : String
    + fechaCreacion : long
    + fechaLimiteRespuesta : long
    + version : int
  }
}

' ============================================================
' TRANSACCIONES
' ============================================================
rectangle "transacciones.json\n<<Transaccion>>" as R_TRANSACCION {
  class "Transaccion" as TRANSACCION <<entity>> {
    + idTransaccion : String [PK]
    + idPublicacion : String [FK]
    + idOfertante : String [FK]
    + idDemandante : String [FK]
    + estado : String
    + creditosComprometidos : int
    + confirmacionOfertante : boolean
    + confirmacionDemandante : boolean
    + fechaCreacion : long
    + idIncidencia : String [FK]
    + idSolicitanteCancelacion : String [FK]
    + motivoCancelacion : String [FK]
    + cancelacionAceptada : boolean
    + version : int
  }
  class "Resena (embebida)" as RESENA_EMB <<emb>> {
    + idResena : String [PK]
    + idTransaccion : String [FK]
    + idEmisor : String [FK]
    + idReceptor : String [FK]
    + calificacion : int
    + fechaCreacion : long
    + version : int
  }
  TRANSACCION *-- RESENA_EMB
}

' ============================================================
' INCIDENCIAS
' ============================================================
rectangle "incidencias.json\n<<Incidencia>>" as R_INCIDENCIA {
  class "Incidencia" as INCIDENCIA <<entity>> {
    + idIncidencia : String [PK]
    + idTransaccion : String [FK]
    + idUsuarioReportante : String [FK]
    + descripcion : String
    + urlEvidencia : String
    + idUsuarioDefensor : String [FK]
    + descripcionDefensa : String
    + urlEvidenciaDefensa : String
    + estado : String
    + fechaCreacion : long
  }
}

' ============================================================
' RESENAS (standalone)
' ============================================================
rectangle "resenas.json\n<<Resena>>" as R_RESENA {
  class "Resena" as RESENA <<entity>> {
    + idResena : String [PK]
    + idTransaccion : String [FK]
    + idEmisor : String [FK]
    + idReceptor : String [FK]
    + calificacion : int
    + fechaCreacion : long
    + version : int
  }
}

' ============================================================
' MOTIVOS CANCELACION
' ============================================================
rectangle "motivos_cancelacion.json\n<<MotivoCancelacion>>" as R_MOT_CANCEL {
  class "MotivoCancelacion" as MOT_CANCEL <<entity>> {
    + id : String [PK]
    + descripcion : String
    + activo : boolean
  }
}

' ============================================================
' CORREOS PERMITIDOS
' ============================================================
rectangle "correos_permitidos.json\n<<CorreoPermitido>>" as R_CORREO {
  class "CorreoPermitido" as CORREO <<entity>> {
    + id : String [PK]
    + correo : String
    + fechaCreacion : long
  }
}

' ============================================================
' NOTIFICACIONES
' ============================================================
rectangle "notificaciones.json\n<<Notificacion>>" as R_NOTIFICACION {
  class "Notificacion" as NOTIFICACION <<entity>> {
    + idNotificacion : String [PK]
    + idRemitente : String [FK]
    + idDestinatario : String [FK]
    + mensaje : String
    + tipo : String
    + estadoLectura : boolean
    + fechaCreacion : long
    + idReferencia : String
    + idReferenciaAuxiliar : String
  }
}

' ============================================================
' LOGROS
' ============================================================
rectangle "logros.json\n<<Logro>>" as R_LOGRO {
  class "Logro" as LOGRO <<entity>> {
    + idLogro : String [PK]
    + nombre : String
    + descripcion : String
    + tipoCriterio : String
    + bonoCreditos : int
    + activo : boolean
  }
}

' ============================================================
' LOGROS DESBLOQUEADOS
' ============================================================
rectangle "logros_desbloqueados.json\n<<LogroDesbloqueado>>" as R_LOGRO_DESB {
  class "LogroDesbloqueado" as LOGRO_DESB <<entity>> {
    + id : String [PK]
    + idUsuario : String [FK]
    + idLogro : String [FK]
    + fechaDesbloqueo : long
  }
}

' ============================================================
' PODIO SEMANAL
' ============================================================
rectangle "podio_semanal.json\n<<PodioSemanal>>\n(objeto unico)" as R_PODIO {
  class "PodioSemanal" as PODIO <<entity>> {
    + idPodio : String [PK]
    + proveedorEliteId : String [FK]
    + proveedorEliteNombre : String
    + proveedorEliteServicios : int
    + motorEconomiaId : String [FK]
    + motorEconomiaNombre : String
    + motorEconomiaTransacciones : int
    + embajadorCalidadId : String [FK]
    + embajadorCalidadNombre : String
    + embajadorCalidadPromedio : double
    + fechaInicioSemana : long
    + fechaFinSemana : long
    + fechaCalculo : long
  }
}

' ============================================================
' SUBASTAS
' ============================================================
rectangle "subastas.json\n<<Subasta>>" as R_SUBASTA {
  class "Subasta" as SUBASTA <<entity>> {
    + id : String [PK]
    + idPropietario : String [FK]
    + nombreActivo : String
    + descripcion : String
    + estadoFisico : String
    + imagenesUrls : List~String~
    + fechaInicio : String
    + fechaFinalizacionLicitacion : String
    + estado : String
    + propietarioConfirmoEntrega : boolean
    + ganadorConfirmoEntrega : boolean
    + version : int
  }
  class "Propuesta []" as PROPUESTA <<emb>> {
    + idPropuesta : String [PK]
    + idSubasta : String [FK]
    + idPostor : String [FK]
    + descripcion : String
    + estadoPropuesta : String
    + imagenesUrls : List~String~
    + fechaPropuesta : String
  }
  class "Bien Ofrecido []" as BIEN <<emb>> {
    + nombre : String
    + cantidad : int
  }
  SUBASTA *-- PROPUESTA
  PROPUESTA *-- BIEN
}

' ============================================================
' FLECHAS ENTRE ARCHIVOS JSON
' ============================================================

''''''''''''''''' DESDE usuarios.json '''''''''''''''''
HAB_OFRE --> HABILIDAD : habilidadBase.id
NEC_REG --> HABILIDAD : necesidadBase.id

''''''''''''''''' DESDE publicaciones.json '''''''''''''''''
PUBLICACION --> R_USUARIO : idUsuario
PUBLICACION --> HAB_OFRE : idInstanciaCatalogo
PUBLICACION --> NEC_REG : idInstanciaCatalogo

''''''''''''''''' DESDE solicitudes.json '''''''''''''''''
SOLICITUD --> PUBLICACION : idPublicacion
SOLICITUD --> R_USUARIO : idSolicitante

''''''''''''''''' DESDE transacciones.json '''''''''''''''''
TRANSACCION --> PUBLICACION : idPublicacion
TRANSACCION --> R_USUARIO : idOfertante
TRANSACCION --> R_USUARIO : idDemandante
TRANSACCION --> R_INCIDENCIA : idIncidencia
TRANSACCION --> R_MOT_CANCEL : motivoCancelacion
TRANSACCION --> R_USUARIO : idSolicitanteCancelacion
RESENA_EMB --> R_USUARIO : idEmisor
RESENA_EMB --> R_USUARIO : idReceptor

''''''''''''''''' DESDE incidencias.json '''''''''''''''''
INCIDENCIA --> TRANSACCION : idTransaccion
INCIDENCIA --> R_USUARIO : idUsuarioReportante
INCIDENCIA --> R_USUARIO : idUsuarioDefensor

''''''''''''''''' DESDE resenas.json '''''''''''''''''
RESENA --> TRANSACCION : idTransaccion
RESENA --> R_USUARIO : idEmisor
RESENA --> R_USUARIO : idReceptor

''''''''''''''''' DESDE notificaciones.json '''''''''''''''''
NOTIFICACION --> R_USUARIO : idRemitente
NOTIFICACION --> R_USUARIO : idDestinatario

''''''''''''''''' DESDE logros_desbloqueados.json '''''''''''''''''
LOGRO_DESB --> R_USUARIO : idUsuario
LOGRO_DESB --> LOGRO : idLogro

''''''''''''''''' DESDE podio_semanal.json '''''''''''''''''
PODIO --> R_USUARIO : proveedorEliteId
PODIO --> R_USUARIO : motorEconomiaId
PODIO --> R_USUARIO : embajadorCalidadId

''''''''''''''''' DESDE subastas.json '''''''''''''''''
SUBASTA --> R_USUARIO : idPropietario
PROPUESTA --> R_USUARIO : idPostor

@enduml
