@startuml
skinparam packageStyle rectangle
skinparam backgroundColor #FEFEFE
skinparam defaultFontName Consolas
skinparam defaultFontSize 11
hide circle
hide empty members

title "Vista de Datos — EntreNos Motor de Intercambio\nPersistencia JSON Plana"

legend right
  PK = Clave primaria
  FK = Clave foranea (ID referenciado)
  emb = Objeto embebido en JSON del padre
  =====
  Archivos en /backend/data/
endlegend

' ========================================================================
' MODULO: IDENTIDAD
' ========================================================================
package "Identidad" as P_IDENTIDAD {
  class "Usuario" as USUARIO <<entity>> {
    + id : String [PK]
    + nombre : String
    + correoElectronico : String
    + telefono : String
    + descripcionPersonal : String
    + contrasenaHash : String
    + version : int
    + estado : String
    + rol : String
    + intentosFallidos : int
    + promedioCalificacion : float
    + cantidadCalificaciones : int
    + esVecinoDestacado : boolean
    + urlFotoPerfil : String
    + reportesFraudeValidados : int
  }

  class "Monedero" as MONEDERO <<emb>> {
    + creditosDisponibles : float
    + creditosRetenidos : float
    + creditosPorLogros : float
  }

  class "Catalogo Usuario" as CATALOGO <<emb>> {
    + completado : boolean
  }

  class "Habilidad Ofrecida" as HAB_OFRE <<emb>> {
    + idInstancia : String [PK]
    + precioCreditos : int
    + descripcionServicio : String
  }

  class "Necesidad Registrada" as NEC_REG <<emb>> {
    + idInstancia : String [PK]
    + descripcionCondiciones : String
  }

  class "Habilidad" as HABILIDAD <<entity>> {
    + id : String [PK]  HAB-NNN
    + categoria : String
  }
}

' ========================================================================
' MODULO: PUBLICACION E INTERCAMBIO
' ========================================================================
package "Publicacion e Intercambio" as P_PUBLICACION {
  class "Publicacion" as PUBLICACION <<entity>> {
    + idPublicacion : String [PK]  PUB-XXXXXXXX
    + idUsuario : String [FK]
    + tipoPublicacion : String
    + nombreServicio : String
    + descripcion : String
    + precioCreditos : int
    + disponible : boolean
    + idInstanciaCatalogo : String [FK]
    + version : int
  }

  class "Solicitud" as SOLICITUD <<entity>> {
    + idSolicitud : String [PK]  SOL-XXXXXXXX
    + idPublicacion : String [FK]
    + idSolicitante : String [FK]
    + estado : String
    + fechaCreacion : long
    + fechaLimiteRespuesta : long
    + version : int
  }

  class "Transaccion" as TRANSACCION <<entity>> {
    + idTransaccion : String [PK]  TX-XXXXXXXX
    + idPublicacion : String [FK]
    + idOfertante : String [FK]
    + idDemandante : String [FK]
    + estado : String
    + creditosRetenidos : int
    + confirmacionOfertante : boolean
    + confirmacionDemandante : boolean
    + fechaCreacion : long
    + idIncidencia : String [FK]
    + idSolicitanteCancelacion : String [FK]
    + motivoCancelacion : String
    + cancelacionAceptada : boolean
    + version : int
  }

  class "Incidencia" as INCIDENCIA <<entity>> {
    + idIncidencia : String [PK]  INC-XXXXXXXX
    + idTransaccion : String [FK]
    + idUsuarioReportante : String [FK]
    + descripcion : String
    + urlEvidencia : String
    + idUsuarioDefensor : String [FK]
    + descripcionDefensa : String
    + urlEvidenciaDefensa : String
    + estado : String
    + fechaCreacion : long
  }

  class "Resena" as RESENA <<entity>> {
    + idResena : String [PK]  RES-XXXXXXXX
    + idTransaccion : String [FK]
    + idEmisor : String [FK]
    + idReceptor : String [FK]
    + calificacion : int
    + fechaCreacion : long
    + version : int
  }

  class "Motivo Cancelacion" as MOT_CANCEL <<entity>> {
    + id : String [PK]  MC-NNN
    + descripcion : String
    + activo : boolean
  }
}

' ========================================================================
' MODULO: SUBASTA
' ========================================================================
package "Subasta" as P_SUBASTA {
  class "Subasta" as SUBASTA <<entity>> {
    + id : String [PK]  SUB-XXXXXXXX
    + idPropietario : String [FK]
    + nombreActivo : String
    + descripcion : String
    + estadoFisico : String
    + imagenesUrls : List~String~
    + fechaInicio : String
    + fechaFinalizacionLicitacion : String
    + estado : String
    + idPropuestaGanadora : String [FK]
    + propietarioConfirmoEntrega : boolean
    + ganadorConfirmoEntrega : boolean
    + version : int
  }

  class "Propuesta" as PROPUESTA <<emb>> {
    + idPropuesta : String [PK]  PROP-XXXXXX
    + idSubasta : String [FK]
    + idPostor : String [FK]
    + descripcion : String
    + estadoFisico : String
    + estadoPropuesta : String
    + imagenesUrls : List~String~
    + fechaPropuesta : String
  }

  class "Bien Ofrecido" as BIEN <<emb>> {
    + nombre : String
    + cantidad : int
  }
}

' ========================================================================
' MODULO: GAMIFICACION
' ========================================================================
package "Gamificacion" as P_GAMIF {
  class "Logro" as LOGRO <<entity>> {
    + idLogro : String [PK]
    + nombre : String
    + descripcion : String
    + tipoCriterio : String
    + bonoCreditos : int
    + activo : boolean
  }

  class "Logro Desbloqueado" as LOGRO_DESB <<entity>> {
    + id : String [PK]
    + idUsuario : String [FK]
    + idLogro : String [FK]
    + fechaDesbloqueo : long
  }

  class "Podio Semanal" as PODIO <<entity>> {
    + idPodio : String [PK]  PD-XXXXXXXX
    + proveedorEliteId : String [FK]
    + proveedorEliteNombre : String
    + proveedorEliteServicios : int
    + motorEconomiaId : String [FK]
    + motorEconomiaNombre : String
    + motorEconomiaTransacciones : int
    + embajadorCalidadId : String [FK]
    + embajadorCalidadNombre : String
    + embajadorCalidadPromedio : double
    + fechaInicioSemana : long
    + fechaFinSemana : long
    + fechaCalculo : long
  }
}

' ========================================================================
' MODULO: NOTIFICACION
' ========================================================================
package "Notificaciones" as P_NOTIF {
  class "Notificacion" as NOTIFICACION <<entity>> {
    + idNotificacion : String [PK]
    + idRemitente : String [FK]
    + idDestinatario : String [FK]
    + mensaje : String
    + tipo : String
    + estadoLectura : boolean
    + fechaCreacion : long
  }
}

' ========================================================================
' RELACIONES
' ========================================================================

''''''''''''''''''' IDENTIDAD '''''''''''''''''''
USUARIO *-- MONEDERO : contiene
USUARIO *-- CATALOGO : contiene
CATALOGO *-- HAB_OFRE : contiene
CATALOGO *-- NEC_REG : contiene
HAB_OFRE --> HABILIDAD : habilidadBase
NEC_REG --> HABILIDAD : necesidadBase

''''''''''''''''''' PUBLICACION '''''''''''''''''''
USUARIO --> PUBLICACION : idUsuario
PUBLICACION --> HAB_OFRE : idInstanciaCatalogo
PUBLICACION --> NEC_REG : idInstanciaCatalogo
PUBLICACION --> SOLICITUD : idPublicacion
USUARIO --> SOLICITUD : idSolicitante
PUBLICACION --> TRANSACCION : idPublicacion
USUARIO --> TRANSACCION : idOfertante
USUARIO --> TRANSACCION : idDemandante
TRANSACCION --> INCIDENCIA : idIncidencia
TRANSACCION *-- RESENA : contiene (embebida)
INCIDENCIA --> TRANSACCION : idTransaccion
USUARIO --> INCIDENCIA : idUsuarioReportante
USUARIO --> INCIDENCIA : idUsuarioDefensor
RESENA --> TRANSACCION : idTransaccion
USUARIO --> RESENA : idEmisor / idReceptor

''''''''''''''''''' SUBASTA '''''''''''''''''''
USUARIO --> SUBASTA : idPropietario
SUBASTA *-- PROPUESTA : contiene
PROPUESTA *-- BIEN : contiene
USUARIO --> PROPUESTA : idPostor

''''''''''''''''''' GAMIFICACION '''''''''''''''''''
USUARIO --> LOGRO_DESB : idUsuario
LOGRO --> LOGRO_DESB : idLogro
USUARIO --> PODIO : proveedorEliteId
USUARIO --> PODIO : motorEconomiaId
USUARIO --> PODIO : embajadorCalidadId

''''''''''''''''''' NOTIFICACION '''''''''''''''''''
USUARIO --> NOTIFICACION : idRemitente
USUARIO --> NOTIFICACION : idDestinatario

' ========================================================================
' NOTAS
' ========================================================================
note top of USUARIO
  Archivo: usuarios.json
  Embebe Monedero, Catalogo,
  HabilidadOfrecida,
  NecesidadRegistrada.
end note

note top of PUBLICACION : Archivo: publicaciones.json
note top of SOLICITUD : Archivo: solicitudes.json
note top of TRANSACCION : Archivo: transacciones.json (embebe Resena)
note top of INCIDENCIA : Archivo: incidencias.json
note top of RESENA : Archivo: resenas.json
note top of SUBASTA : Archivo: subastas.json (embebe Propuesta + Bien)
note top of LOGRO : Archivo: logros.json
note top of LOGRO_DESB : Archivo: logros_desbloqueados.json
note top of PODIO : Archivo: podio_semanal.json (OBJETO UNICO)
note top of MOT_CANCEL : Archivo: motivos_cancelacion.json
note top of NOTIFICACION : Archivo: notificaciones.json
note top of HABILIDAD : Archivo: habilidades.json

@enduml
