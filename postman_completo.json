    {
      "name": "HU3 — Transacciones Seguras y Valoración",
      "item": [
        {
          "name": "3.1 María acepta solicitud de Juan (créditos retenidos)",
          "event": [
            { "listen": "test", "script": { "exec": [
              "var body = pm.response.json();",
              "var txId = body.idTransaccion || (body.transaccion ? body.transaccion.idTransaccion : null);",
              "if(txId) pm.collectionVariables.set('id_tx', txId);",
              "pm.test('Transacción creada con créditos retenidos', () => pm.expect(body).to.not.be.empty);"
            ], "type": "text/javascript" } }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token_user2}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\"idUsuario\":\"{{id_user2}}\",\"aceptar\":true}"
            },
            "url": { "raw": "{{base_url}}/api/publicaciones/{{id_pub2}}/responder", "host": ["{{base_url}}"], "path": ["api", "publicaciones", "{{id_pub2}}", "responder"] }
          }
        },
        {
          "name": "3.2 Confirmar ofertante (María confirma entrega)",
          "event": [
            { "listen": "test", "script": { "exec": [
              "var body = pm.response.json();",
              "var logros = body.nuevosLogros || [];",
              "pm.test('Confirmación exitosa', () => pm.expect(body.transaccion).to.not.be.empty);",
              "if(logros.length > 0) pm.test('Logros desbloqueados!', () => pm.expect(logros.length).to.be.above(0));"
            ], "type": "text/javascript" } }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_user2}}" }],
            "body": { "mode": "raw", "raw": "" },
            "url": { "raw": "{{base_url}}/api/transacciones/{{id_tx}}/confirmar-ofertante", "host": ["{{base_url}}"], "path": ["api", "transacciones", "{{id_tx}}", "confirmar-ofertante"] }
          }
        },
        {
          "name": "3.3 Confirmar demandante (Juan confirma recepción)",
          "event": [
            { "listen": "test", "script": { "exec": [
              "var body = pm.response.json();",
              "var logros = body.nuevosLogros || [];",
              "pm.test('Transacción finalizada y pago liberado', () => pm.expect(body.transaccion.estado).to.eql('FINALIZADA'));",
              "if(logros.length > 0) pm.test('¡Logros desbloqueados!', () => pm.expect(logros.length).to.be.above(0));"
            ], "type": "text/javascript" } }
          ],
          "request": {
            "method": "POST",
