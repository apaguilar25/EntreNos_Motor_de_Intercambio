              "}",
              "if(body.necesidades && body.necesidades.length > 0) {",
              "    pm.collectionVariables.set('id_instancia_necesidad_juan', body.necesidades[0].idInstancia);",
              "}",
              "pm.test('Perfil obtenido', () => pm.expect(body.id).to.not.be.empty);"
            ], "type": "text/javascript" } }
