{
	"info": {
		"name": "EntreNos - Flujo Completo",
		"description": "Colección para probar todos los cambios estructurales y funcionales (campos eliminados, Incidencia, Top 3 Podio, cancelar solicitud, etc.)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Usuarios",
			"item": [
				{
					"name": "Registrar Usuario A (Vecino 1)",
					"event": [{ "listen": "test", "script": { "exec": ["var jsonData = pm.response.json();", "pm.environment.set(\"idUsuarioA\", jsonData.idUsuario);", "pm.environment.set(\"nombreUsuarioA\", jsonData.nombre);"], "type": "text/javascript" } }],
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"nombre\": \"Ana García\",\n  \"correoElectronico\": \"ana@example.com\",\n  \"telefono\": \"+58 412-111-2233\",\n  \"descripcionPersonal\": \"Diseñadora gráfica y community manager\",\n  \"contrasena\": \"clave123\"\n}"
						},
						"url": {"raw": "http://localhost:8080/api/usuarios/registro", "host": ["http://localhost:8080"], "path": ["api", "usuarios", "registro"]}
					}
				},
				{
					"name": "Registrar Usuario B (Vecino 2)",
					"event": [{ "listen": "test", "script": { "exec": ["var jsonData = pm.response.json();", "pm.environment.set(\"idUsuarioB\", jsonData.idUsuario);", "pm.environment.set(\"nombreUsuarioB\", jsonData.nombre);"], "type": "text/javascript" } }],
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"nombre\": \"Carlos López\",\n  \"correoElectronico\": \"carlos@example.com\",\n  \"telefono\": \"+58 414-222-3344\",\n  \"descripcionPersonal\": \"Electricista y técnico en reparaciones\",\n  \"contrasena\": \"clave456\"\n}"
						},
						"url": {"raw": "http://localhost:8080/api/usuarios/registro", "host": ["http://localhost:8080"], "path": ["api", "usuarios", "registro"]}
					}
				},
				{
					"name": "Obtener Perfil Usuario A",
					"request": {
						"method": "GET",
						"url": {"raw": "http://localhost:8080/api/usuarios/{{idUsuarioA}}", "host": ["http://localhost:8080"], "path": ["api", "usuarios", "{{idUsuarioA}}"]}
					}
				},
				{
					"name": "Obtener Saldo Usuario A",
					"request": {
						"method": "GET",
						"url": {"raw": "http://localhost:8080/api/usuarios/{{idUsuarioA}}/saldo", "host": ["http://localhost:8080"], "path": ["api", "usuarios", "{{idUsuarioA}}", "saldo"]}
					}
				}
			]
		},
		{
			"name": "2. Catálogo de Habilidades (bootstrap)",
			"item": [
				{
					"name": "Listar Habilidades Base",
					"event": [{ "listen": "test", "script": { "exec": ["var jsonData = pm.response.json();", "if(jsonData.length > 0) pm.environment.set(\"idHabilidadDisenio\", jsonData[0].id);"], "type": "text/javascript" } }],
					"request": {
						"method": "GET",
						"url": {"raw": "http://localhost:8080/api/habilidades", "host": ["http://localhost:8080"], "path": ["api", "habilidades"]}
					}
				}
			]
		},
		{
			"name": "3. Publicaciones",
			"item": [
				{
					"name": "Crear Publicacion (Oferta - HABILIDAD) de A",
					"event": [{ "listen": "test", "script": { "exec": ["var jsonData = pm.response.json();", "pm.environment.set(\"idPublicacionA\", jsonData.idPublicacion);"], "type": "text/javascript" } }],
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"idUsuario\": \"{{idUsuarioA}}\",\n  \"tipoPublicacion\": \"HABILIDAD\",\n  \"nombreServicio\": \"Diseño Gráfico\",\n  \"descripcion\": \"Diseño de logos y material publicitario\",\n  \"precioCreditos\": 30\n}"
						},
						"url": {"raw": "http://localhost:8080/api/publicaciones", "host": ["http://localhost:8080"], "path": ["api", "publicaciones"]}
					}
				},
				{
					"name": "Crear Publicacion (Necesidad) de B",
					"event": [{ "listen": "test", "script": { "exec": ["var jsonData = pm.response.json();", "pm.environment.set(\"idPublicacionB\", jsonData.idPublicacion);"], "type": "text/javascript" } }],
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"idUsuario\": \"{{idUsuarioB}}\",\n  \"tipoPublicacion\": \"NECESIDAD\",\n  \"nombreServicio\": \"Diseño Gráfico\",\n  \"descripcion\": \"Necesito un logo para mi negocio\",\n  \"precioCreditos\": 0\n}"
						},
						"url": {"raw": "http://localhost:8080/api/publicaciones", "host": ["http://localhost:8080"], "path": ["api", "publicaciones"]}
					}
				},
				{
					"name": "Listar Publicaciones (filtradas y DTO con nombreUsuario reputacion)",
					"request": {
						"method": "GET",
						"url": {"raw": "http://localhost:8080/api/publicaciones?tipo=HABILIDAD&servicio=diseño", "host": ["http://localhost:8080"], "path": ["api", "publicaciones"], "query": [{"key": "tipo", "value": "HABILIDAD"}, {"key": "servicio", "value": "diseño"}]}
					}
				},
				{
					"name": "Publicaciones del Usuario A (nuevo endpoint)",
					"request": {
						"method": "GET",
						"url": {"raw": "http://localhost:8080/api/publicaciones/usuario/{{idUsuarioA}}", "host": ["http://localhost:8080"], "path": ["api", "publicaciones", "usuario", "{{idUsuarioA}}"]}
					}
				},
				{
					"name": "Verificar DTO: sin fechaCreacion, esVecinoDestacado desde Usuario",
					"request": {
						"method": "GET",
						"url": {"raw": "http://localhost:8080/api/publicaciones/{{idPublicacionA}}", "host": ["http://localhost:8080"], "path": ["api", "publicaciones", "{{idPublicacionA}}"]}
					}
				},
				{
					"name": "Recomendaciones para Usuario B",
					"request": {
						"method": "GET",
						"url": {"raw": "http://localhost:8080/api/publicaciones/recomendadas/{{idUsuarioB}}", "host": ["http://localhost:8080"], "path": ["api", "publicaciones", "recomendadas", "{{idUsuarioB}}"]}
					}
				}
			]
		},
		{
			"name": "4. Solicitudes",
			"item": [
				{
					"name": "Solicitar Servicio (B solicita a A)",
					"event": [{ "listen": "test", "script": { "exec": ["var jsonData = pm.response.json();", "pm.environment.set(\"idSolicitud\", jsonData.idSolicitud);"], "type": "text/javascript" } }],
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"idUsuario\": \"{{idUsuarioB}}\"\n}"
						},
						"url": {"raw": "http://localhost:8080/api/publicaciones/{{idPublicacionA}}/solicitar", "host": ["http://localhost:8080"], "path": ["api", "publicaciones", "{{idPublicacionA}}", "solicitar"]}
					}
				},
				{
					"name": "Cancelar Solicitud (solo PENDIENTE) - nuevo endpoint",
					"event": [{ "listen": "test", "script": { "exec": ["var jsonData = pm.response.json();", "console.log(\"Solicitud cancelada:\", jsonData.estado);"], "type": "text/javascript" } }],
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"idUsuario\": \"{{idUsuarioB}}\"\n}"
						},
						"url": {"raw": "http://localhost:8080/api/solicitudes/{{idSolicitud}}/cancelar", "host": ["http://localhost:8080"], "path": ["api", "solicitudes", "{{idSolicitud}}", "cancelar"]}
					}
				}
			]
		},
		{
			"name": "5. Flujo Transacción Completo",
			"item": [
				{
					"name": "Solicitar Servicio (B solicita a A) - segunda intento",
					"event": [{ "listen": "test", "script": { "exec": ["var jsonData = pm.response.json();", "pm.environment.set(\"idSolicitud2\", jsonData.idSolicitud);"], "type": "text/javascript" } }],
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"idUsuario\": \"{{idUsuarioB}}\"\n}"
						},
						"url": {"raw": "http://localhost:8080/api/publicaciones/{{idPublicacionA}}/solicitar", "host": ["http://localhost:8080"], "path": ["api", "publicaciones", "{{idPublicacionA}}", "solicitar"]}
					}
				},
				{
					"name": "Aceptar Solicitud (A responde OK)",
					"event": [{ "listen": "test", "script": { "exec": ["var jsonData = pm.response.json();", "if(jsonData.estado === 'ACEPTADA') {", "  console.log('Solicitud ACEPTADA, transacción creada automáticamente');", "}", "var transacciones = pm.sendRequest({ url: 'http://localhost:8080/api/transacciones', method: 'GET' });", "var txList = JSON.parse(transacciones);", "if(txList.length > 0) {", "  var ultimaTx = txList[txList.length - 1];", "  pm.environment.set('idTransaccion', ultimaTx.idTransaccion);", "  pm.environment.set('idOfertanteTx', ultimaTx.idOfertante);", "  pm.environment.set('idDemandanteTx', ultimaTx.idDemandante);", "}"], "type": "text/javascript" } }],
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"idUsuario\": \"{{idUsuarioA}}\",\n  \"aceptar\": true\n}"
						},
						"url": {"raw": "http://localhost:8080/api/solicitudes/{{idSolicitud2}}/responder", "host": ["http://localhost:8080"], "path": ["api", "solicitudes", "{{idSolicitud2}}", "responder"]}
					}
				},
				{
					"name": "Ver Transaccion (sin nombreServicio / descripcion / fechaLimiteAceptacion)",
					"request": {
						"method": "GET",
						"url": {"raw": "http://localhost:8080/api/transacciones/{{idTransaccion}}", "host": ["http://localhost:8080"], "path": ["api", "transacciones", "{{idTransaccion}}"]}
					}
				},
				{
					"name": "Confirmar Ofertante (A confirma entrega)",
					"request": {
						"method": "POST",
						"url": {"raw": "http://localhost:8080/api/transacciones/{{idTransaccion}}/confirmar-ofertante", "host": ["http://localhost:8080"], "path": ["api", "transacciones", "{{idTransaccion}}", "confirmar-ofertante"]}
					}
				},
				{
					"name": "Confirmar Demandante (B confirma recepción)",
					"request": {
						"method": "POST",
						"url": {"raw": "http://localhost:8080/api/transacciones/{{idTransaccion}}/confirmar-demandante", "host": ["http://localhost:8080"], "path": ["api", "transacciones", "{{idTransaccion}}", "confirmar-demandante"]}
					}
				},
				{
					"name": "Calificar Transacción (sin comentario)",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"idUsuario\": \"{{idDemandanteTx}}\",\n  \"calificacion\": 5\n}"
						},
						"url": {"raw": "http://localhost:8080/api/transacciones/{{idTransaccion}}/calificar", "host": ["http://localhost:8080"], "path": ["api", "transacciones", "{{idTransaccion}}", "calificar"]}
					}
				}
			]
		},
		{
			"name": "6. Incidencias (nuevo modelo)",
			"item": [
				{
					"name": "Crear y finalizar otra transacción para probar incidencia",
					"event": [{ "listen": "test", "script": { "exec": ["// This will only work if there's a transaction in INICIADA state", "console.log('Para probar incidencia, primero inicia una transacción y confirma solo un lado');"], "type": "text/javascript" } }],
					"request": {
						"method": "GET",
						"url": {"raw": "http://localhost:8080/api/publicaciones", "host": ["http://localhost:8080"], "path": ["api", "publicaciones"]}
					}
				},
				{
					"name": "Reportar Incidencia (requiere transacción INICIADA + descripción >= 20 chars)",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"idUsuario\": \"{{idDemandanteTx}}\",\n  \"descripcion\": \"El servicio entregado no coincide con lo acordado en la publicación original. Solucionar por favor.\",\n  \"urlEvidencia\": \"https://ejemplo.com/evidencia.jpg\"\n}"
						},
						"url": {"raw": "http://localhost:8080/api/transacciones/{{idTransaccion}}/reportar-incidencia", "host": ["http://localhost:8080"], "path": ["api", "transacciones", "{{idTransaccion}}", "reportar-incidencia"]}
					}
				}
			]
		},
		{
			"name": "7. Reputación",
			"item": [
				{
					"name": "Historial de Calificaciones de A (resenas por usuario)",
					"request": {
						"method": "GET",
						"url": {"raw": "http://localhost:8080/api/reputacion/usuario/{{idUsuarioA}}", "host": ["http://localhost:8080"], "path": ["api", "reputacion", "usuario", "{{idUsuarioA}}"]}
					}
				},
				{
					"name": "Todas las Resenas (sin campo comentario)",
					"request": {
						"method": "GET",
						"url": {"raw": "http://localhost:8080/api/reputacion", "host": ["http://localhost:8080"], "path": ["api", "reputacion"]}
					}
				}
			]
		},
		{
			"name": "8. Gamificación",
			"item": [
				{
					"name": "Logros de Usuario A",
					"request": {
						"method": "GET",
						"url": {"raw": "http://localhost:8080/api/logros/usuario/{{idUsuarioA}}", "host": ["http://localhost:8080"], "path": ["api", "logros", "usuario", "{{idUsuarioA}}"]}
					}
				},
				{
					"name": "Logros Desbloqueados de A (sin icono)",
					"request": {
						"method": "GET",
						"url": {"raw": "http://localhost:8080/api/logros/usuario/{{idUsuarioA}}/desbloqueados", "host": ["http://localhost:8080"], "path": ["api", "logros", "usuario", "{{idUsuarioA}}", "desbloqueados"]}
					}
				}
			]
		},
		{
			"name": "9. Podio Semanal (Top 3)",
			"item": [
				{
					"name": "Ver Top 3 del Podio (nuevo formato con listas)",
					"request": {
						"method": "GET",
						"url": {"raw": "http://localhost:8080/api/podio", "host": ["http://localhost:8080"], "path": ["api", "podio"]}
					}
				},
				{
					"name": "Calcular Podio Semanal Manualmente",
					"request": {
						"method": "POST",
						"url": {"raw": "http://localhost:8080/api/podio/calcular", "host": ["http://localhost:8080"], "path": ["api", "podio", "calcular"]}
					}
				}
			]
		},
		{
			"name": "10. Admin - Sanción de Fraude",
			"item": [
				{
					"name": "Reportar Fraude Validado (suspende tras 2 reportes)",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"idUsuarioReportado\": \"{{idUsuarioB}}\",\n  \"idUsuarioReportante\": \"{{idUsuarioA}}\"\n}"
						},
						"url": {"raw": "http://localhost:8080/api/admin/sanciones/fraude", "host": ["http://localhost:8080"], "path": ["api", "admin", "sanciones", "fraude"]}
					}
				}
			]
		}
	]
