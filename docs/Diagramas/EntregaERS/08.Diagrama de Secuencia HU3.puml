@startuml

skinparam style strictuml
skinparam DefaultFontName Arial
skinparam SequenceLifeLineBackgroundColor #E8F4F8
skinparam SequenceLifeLineBorderColor #2C3E50
skinparam ParticipantBackgroundColor #E8F4F8
skinparam ParticipantBorderColor #2C3E50
skinparam noteBackgroundColor #FDEDEC
skinparam noteBorderColor #E74C3C

title <size:20> Diagrama de Secuencia HU3: Gestión de Transacciones y Calificaciones

actor "<u>: Usuario</u>" as User
participant "<u>: Sistema</u>" as UI
control "<u>: GestionTransaccion</u>" as GT
control "<u>: GestionUsuario</u>" as GU
database "<u>: PersistenciaTransacciones</u>\n(transacciones.json)" as PT
database "<u>: PersistenciaUsuario</u>\n(usuarios.json)" as PU

== 1. Inicialización de la Transacción ==
User -> UI: Preparar inicio transacción
activate UI

UI -> GT: registrarTransaccion(idOfertante, idDemandante, nombreServicio)
activate GT

GT -> "<u>: Transaccion</u>" as Tx  : new Transaccion(idOfertante, idDemandante, nombre, descripcion)
GT -> "<u>: Servicio</u>" as Serv  : new Servicio(nombreServicio, descripcion)
GT -> Tx: (Asocia el Servicio a la Transaccion)
GT -> Tx: actualizarEstado(INICIADA)

GT -> PT: guardar(List<Transaccion>)
activate PT
PT --> GT: void
deactivate PT

GT -> GU: buscarUsuario(idDemandante)
activate GU
GU --> GT: usuarioDemandante
deactivate GU

note right of GT
  El sistema descuenta los créditos del
  monedero del demandante y los retiene.
end note
GT -> GT: retenerCreditos()
GT -> PU: guardar(List<Usuario>)

GT -> GT: enviarNotificacion(ambasPartes, "Transacción iniciada", TRANSACCION_ACTUALIZADA)

GT --> UI: transaccionIniciada
deactivate GT

UI --> User: Mostrar datos de contacto y notificación de inicio

== 2. Ejecución y Confirmación ==
note across
  Coordinación externa: Se ejecuta el servicio acordado.
end note

User -> UI: Seleccionar confirmación de servicio realizado/recibido

alt ¿Cuál es el rol del usuario en la transacción? = [Demandante]
    UI -> GT: confirmar(idTransaccion, idDemandante)
    activate GT
    GT -> Tx: setConfirmacionDemandante(true)
    GT --> UI: ok
    deactivate GT
    UI --> User: Mostrar mensaje "Confirmación exitosa"

else [Prestador / Ofertante]
    UI -> GT: confirmar(idTransaccion, idPrestador)
    activate GT
    GT -> Tx: setConfirmacionOfertante(true)
    GT --> UI: ok
    deactivate GT
    UI --> User: Mostrar mensaje "Confirmación exitosa"
end

== 3. Liberación de Fondos y Valoración ==
[-> GT: Evento: La contraparte también confirma su parte
activate GT
note right of GT
  Al estar ambas confirmaciones en "true",
  el sistema procede con la liberación automática.
end note

GT -> GT: liberarCreditos()
GT -> PU: guardar(List<Usuario>)
deactivate GT

alt ¿Cuál es el rol del usuario en la transacción? = [Demandante]
    GT --> UI: solicitarValoracion
    UI --> User: Desplegar ventana obligatoria de valoración (Estrellas)

    User -> UI: Ingresar calificación del servicio [1-5 Estrellas]
    UI -> GT: calificarServicio(idPrestador, puntuacion)
    activate GT

... (27 líneas restantes)

