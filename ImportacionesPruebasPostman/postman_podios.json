      "item": [
        {
          "name": "3.1 Catálogo Ana (3 ofertas a distintos precios)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ofertas\": [\n    { \"idHabilidadCategoria\": \"HAB-004\", \"precioCreditos\": 5, \"descripcionServicio\": \"Limpieza profunda\" },\n    { \"idHabilidadCategoria\": \"HAB-001\", \"precioCreditos\": 10, \"descripcionServicio\": \"Plomeria avanzada\" },\n    { \"idHabilidadCategoria\": \"HAB-003\", \"precioCreditos\": 15, \"descripcionServicio\": \"Muebles a medida\" }\n  ],\n  \"necesidades\": []\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/usuarios/{{idAna}}/catalogo",
              "host": ["{{baseUrl}}"],
              "path": ["api", "usuarios", "{{idAna}}", "catalogo"]
