    {
      "name": "06 - Confirmar transacciones (completar intercambios)",
      "item": [
        {
          "name": "6.1 Obtener IDs de transacciones",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var txs = pm.response.json();",
                "var ultima = txs.length - 1;",
                "pm.collectionVariables.set('tx1', txs[ultima-5].idTransaccion);",
                "pm.collectionVariables.set('tx2', txs[ultima-4].idTransaccion);",
                "pm.collectionVariables.set('tx3', txs[ultima-3].idTransaccion);",
                "pm.collectionVariables.set('tx4', txs[ultima-2].idTransaccion);",
                "pm.collectionVariables.set('tx5', txs[ultima-1].idTransaccion);",
                "pm.collectionVariables.set('tx6', txs[ultima].idTransaccion);",
                "console.log('TXs guardadas:', txs.length);"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/transacciones",
              "host": ["{{baseUrl}}"],
              "path": ["api", "transacciones"]
            }
          }
        },
        {
          "name": "6.2 Completar TX1 (Ana confirma → Diana confirma + califica 5)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "" },
            "url": {
              "raw": "{{baseUrl}}/api/transacciones/{{tx1}}/confirmar-ofertante",
              "host": ["{{baseUrl}}"],
              "path": ["api", "transacciones", "{{tx1}}", "confirmar-ofertante"]
            }
          }
        },
        {
          "name": "6.3 Diana confirma TX1",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "" },
            "url": {
              "raw": "{{baseUrl}}/api/transacciones/{{tx1}}/confirmar-demandante",
              "host": ["{{baseUrl}}"],
              "path": ["api", "transacciones", "{{tx1}}", "confirmar-demandante"]
            }
          }
        },
        {
          "name": "6.4 Diana califica TX1 (5 estrellas)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idUsuario\": \"{{idDiana}}\",\n  \"calificacion\": 5\n}"
