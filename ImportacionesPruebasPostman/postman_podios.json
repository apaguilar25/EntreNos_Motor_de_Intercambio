    {
      "name": "07 - Podio",
      "item": [
        {
          "name": "7.1 Calcular Podio Semanal",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var r = pm.response.json();",
                "console.log('Podio calculado:', r.idPodio);",
                "pm.test('Podio debe tener proveedorElite (Ana con 3 TXs)', function() {",
                "  pm.expect(r.proveedorElite).to.not.be.empty;",
                "  pm.expect(r.proveedorElite.length).to.eql(3);",
                "});",
                "pm.test('Motor Economia debe tener 3', function() {",
                "  pm.expect(r.motorEconomia.length).to.eql(3);",
                "});",
                "pm.test('Embajador Calidad debe tener 3', function() {",
                "  pm.expect(r.embajadorCalidad.length).to.eql(3);",
                "});",
                "// Imprimir resumen del podio",
                "console.log('--- PROVEEDOR ELITE ---');",
                "r.proveedorElite.forEach(function(e, i) {",
                "  console.log((i+1) + '. ' + e.nombreUsuario + ' - ' + e.valor + ' TXs');",
                "});",
                "console.log('--- MOTOR ECONOMIA ---');",
                "r.motorEconomia.forEach(function(e, i) {",
                "  console.log((i+1) + '. ' + e.nombreUsuario + ' - ' + e.valor + ' creditos');",
                "});",
                "console.log('--- EMBAJADOR CALIDAD ---');",
                "r.embajadorCalidad.forEach(function(e, i) {",
                "  console.log((i+1) + '. ' + e.nombreUsuario + ' - ' + e.valor + ' estrellas');",
                "});"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/podio/calcular",
              "host": ["{{baseUrl}}"],
              "path": ["api", "podio", "calcular"]
            }
          }
        },
        {
          "name": "7.2 Ver Podio (GET)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var r = pm.response.json();",
                "console.log('Podio:', r.idPodio);",
                "pm.test('Podio obtenido correctamente', function() {",
                "  pm.expect(r.proveedorElite).to.not.be.empty;",
                "});",
                "console.log('--- PROVEEDOR ELITE ---');",
                "r.proveedorElite.forEach(function(e, i) {",
                "  console.log((i+1) + '. ' + e.nombreUsuario + ' - ' + e.valor);",
                "});",
                "console.log('--- MOTOR ECONOMIA ---');",
                "r.motorEconomia.forEach(function(e, i) {",
                "  console.log((i+1) + '. ' + e.nombreUsuario + ' - ' + e.valor);",
                "});",
                "console.log('--- EMBAJADOR CALIDAD ---');",
                "r.embajadorCalidad.forEach(function(e, i) {",
                "  console.log((i+1) + '. ' + e.nombreUsuario + ' - ' + e.valor);",
                "});"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/podio",
              "host": ["{{baseUrl}}"],
              "path": ["api", "podio"]
            }
          }
        },
        {
          "name": "7.3 Recalcular y verificar que se actualiza",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var r = pm.response.json();",
                "console.log('Podio recalculado:', r.idPodio);",
                "pm.test('Sigue teniendo 3 por categoria', function() {",
                "  pm.expect(r.proveedorElite.length).to.eql(3);",
                "  pm.expect(r.motorEconomia.length).to.eql(3);",
                "  pm.expect(r.embajadorCalidad.length).to.eql(3);",
                "});"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
