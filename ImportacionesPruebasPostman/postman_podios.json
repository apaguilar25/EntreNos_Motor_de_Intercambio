    {
      "name": "02 - Obtener habilidades",
      "item": [
        {
          "name": "2.1 Obtener catálogo global de habilidades",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var h = pm.response.json();",
                "pm.collectionVariables.set('catLimpieza', h[0].id);",
                "pm.collectionVariables.set('catPlomeria', h[1].id);",
                "pm.collectionVariables.set('catElectricidad', h[2].id);",
                "pm.collectionVariables.set('catCarpinteria', h[3].id);",
                "console.log('Habilidades OK:', h.length);"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/habilidades",
              "host": ["{{baseUrl}}"],
              "path": ["api", "habilidades"]
            }
          }
        }
      ]
    },
    {
