    {
      "name": "03 - Comparar CON caché vs SIN caché",
      "item": [
        {
          "name": "CON caché - top 10 reputación (GET /api/publicaciones)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var data = pm.response.json();",
                  "var tiempoConCache = pm.response.responseTime;",
                  "pm.collectionVariables.set('tiempoConCache', tiempoConCache);",
                  "console.log('CON cache: ' + data.length + ' pubs, ' + tiempoConCache + ' ms');",
                  "pm.test('Devuelve maximo 10', function() { pm.expect(data.length).to.be.at.most(10); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/publicaciones",
              "host": ["{{baseUrl}}"],
              "path": ["api", "publicaciones"]
            }
          }
        },
        {
          "name": "SIN caché - top 10 reputación (GET /api/publicaciones/sin-cache)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var data = pm.response.json();",
                  "var tiempoSinCache = pm.response.responseTime;",
                  "var tiempoConCache = pm.collectionVariables.get('tiempoConCache');",
                  "console.log('SIN cache: ' + data.length + ' pubs, ' + tiempoSinCache + ' ms');",
                  "console.log('Diferencia: ' + (tiempoSinCache - tiempoConCache) + ' ms');",
                  "pm.test('Devuelve maximo 10', function() { pm.expect(data.length).to.be.at.most(10); });",
                  "pm.test('SIN cache debe ser mas lento que CON cache', function() {",
                  "  pm.expect(tiempoSinCache).to.be.at.least(tiempoConCache);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/publicaciones/sin-cache",
              "host": ["{{baseUrl}}"],
              "path": ["api", "publicaciones", "sin-cache"]
            }
          }
        }
      ]
    },
    {
      "name": "04 - Invalidación al crear/eliminar",
      "item": [
        {
          "name": "Crear nueva publicación",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var resp = pm.response.json();",
                  "pm.collectionVariables.set('pubNueva', resp.idPublicacion);",
                  "console.log('Nueva pub:', resp.idPublicacion);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenA}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idUsuario\": \"{{idA}}\",\n  \"tipoPublicacion\": \"HABILIDAD\",\n  \"nombreServicio\": \"Nueva publicación test\",\n  \"descripcion\": \"Creada para probar refresco de caché\",\n  \"precioCreditos\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/publicaciones",
              "host": ["{{baseUrl}}"],
              "path": ["api", "publicaciones"]
            }
          }
        },
        {
          "name": "CON caché post-creación (caché actualizada)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var data = pm.response.json();",
                  "console.log('CON cache post-creación: ' + data.length + ' pubs');",
                  "pm.test('Caché incluye la nueva publicación', function() {",
                  "  var encontrada = data.some(function(p) { return p.idPublicacion === pm.collectionVariables.get('pubNueva'); });",
                  "  pm.expect(encontrada).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/publicaciones",
              "host": ["{{baseUrl}}"],
              "path": ["api", "publicaciones"]
            }
          }
        },
        {
          "name": "Eliminar publicación 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Eliminación exitosa', function() { pm.expect(pm.response.code).to.equal(204); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenA}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/publicaciones/{{pub1}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "publicaciones", "{{pub1}}"]
            }
          }
        },
        {
          "name": "CON caché post-eliminación (caché actualizada)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var data = pm.response.json();",
                  "console.log('CON cache post-eliminación: ' + data.length + ' pubs');",
                  "pm.test('Caché ya no incluye la publicación eliminada', function() {",
                  "  var encontrada = data.some(function(p) { return p.idPublicacion === pm.collectionVariables.get('pub1'); });",
                  "  pm.expect(encontrada).to.be.false;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/publicaciones",
              "host": ["{{baseUrl}}"],
              "path": ["api", "publicaciones"]
            }
          }
        }
      ]
    }
