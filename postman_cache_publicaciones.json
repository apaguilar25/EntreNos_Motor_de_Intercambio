    {
      "name": "05 - Notificaciones SSE",
      "item": [
        {
          "name": "Suscribirse SSE Ana (GET /api/notificaciones/stream/{{idAna}})",
          "description": "Abre un SSE listener. En Postman la respuesta se ve en el panel Preview como texto/event-stream. Para probar, ejecuta otra request que genere notificacion (ej. crear transaccion) mientras esta pestaña está abierta.",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAna}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/notificaciones/stream/{{idAna}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notificaciones", "stream", "{{idAna}}"]
            }
