    {
      "name": "06 - Validar categorías (crear publicación)",
      "item": [
        {
          "name": "Crear oferta con categoría válida (Yoga: h-yoga-...)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var resp = pm.response.json();",
                "console.log('Pub creada:', resp.idPublicacion);",
                "pm.test('Publicacion creada exitosamente', function() { pm.expect(resp.idPublicacion).to.exist; });"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenAna}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idUsuario\": \"{{idAna}}\",\n  \"tipoPublicacion\": \"HABILIDAD\",\n  \"nombreServicio\": \"Yoga Avanzado\",\n  \"descripcion\": \"Clases de yoga nivel avanzado con posturas complejas\",\n  \"precioCreditos\": 3,\n  \"idInstanciaCatalogo\": \"h-yoga-0001-4000-8000-000000000001\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/publicaciones",
              "host": ["{{baseUrl}}"],
              "path": ["api", "publicaciones"]
            }
          }
        },
        {
          "name": "Crear oferta con categoría inválida (debe fallar 400)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
