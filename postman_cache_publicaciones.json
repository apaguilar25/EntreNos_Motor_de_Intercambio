                "pm.test('Todas son HABILIDAD', function() {",
                "  data.forEach(function(p) { pm.expect(p.tipoPublicacion).to.equal('HABILIDAD'); });",
                "});"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/publicaciones?tipo=HABILIDAD",
              "host": ["{{baseUrl}}"],
              "path": ["api", "publicaciones"],
