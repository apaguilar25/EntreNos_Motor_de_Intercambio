    {
      "name": "02 - Comparar Caché vs Disco",
      "item": [
        {
          "name": "CON caché (GET /api/publicaciones)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var data = pm.response.json();",
                "pm.collectionVariables.set('tiempoConCache', pm.response.responseTime);",
                "console.log('CON cache: ' + data.length + ' pubs, ' + pm.response.responseTime + ' ms');",
                "pm.test('Maximo 10 publicaciones', function() { pm.expect(data.length).to.be.at.most(10); });",
                "pm.test('Ordenado por reputacion descendente', function() {",
                "  for (var i = 1; i < data.length; i++) {",
                "    pm.expect(data[i-1].reputacionUsuario).to.be.at.least(data[i].reputacionUsuario);",
                "  }",
                "});",
                "pm.test('Reputacion con 1 decimal', function() {",
                "  if (data.length > 0) {",
                "    var repStr = data[0].reputacionUsuario.toString();",
                "    var decimales = repStr.includes('.') ? repStr.split('.')[1].length : 0;",
                "    pm.expect(decimales).to.be.at.most(1);",
                "  }",
                "});"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/publicaciones",
              "host": ["{{baseUrl}}"],
              "path": ["api", "publicaciones"]
            }
          }
        },
        {
          "name": "SIN caché (GET /api/publicaciones/sin-cache)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var data = pm.response.json();",
                "var t = pm.response.responseTime;",
                "var tCache = pm.collectionVariables.get('tiempoConCache');",
                "console.log('SIN cache: ' + data.length + ' pubs, ' + t + ' ms');",
                "console.log('Diferencia: ' + (t - tCache) + ' ms (positivo = cache es mas rapido)');",
                "pm.test('Maximo 10 publicaciones', function() { pm.expect(data.length).to.be.at.most(10); });",
                "pm.test('Reputacion con 1 decimal', function() {",
                "  if (data.length > 0) {",
                "    var repStr = data[0].reputacionUsuario.toString();",
                "    var decimales = repStr.includes('.') ? repStr.split('.')[1].length : 0;",
                "    pm.expect(decimales).to.be.at.most(1);",
                "  }",
                "});"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/publicaciones/sin-cache",
              "host": ["{{baseUrl}}"],
              "path": ["api", "publicaciones", "sin-cache"]
            }
          }
        }
      ]
    },
    {
      "name": "03 - Filtrado por tipo (bypasea caché)",
      "item": [
        {
          "name": "Filtrar HABILIDAD (GET /api/publicaciones?tipo=HABILIDAD)",
          "event": [{
            "listen": "test",
            "script": {
