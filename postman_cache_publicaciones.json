{
  "info": {
    "name": "EntreNos - Cache de Publicaciones",
    "description": "Colección para probar el caché de las 10 ofertas más recientes en la landing page. La caché se usa cuando NO hay filtros (tipo, servicio).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" }
  ],
  "item": [
    {
      "name": "01 - Setup: Autorizar correos (admin) + registrar usuarios",
      "item": [
        {
          "name": "1.1 Login como admin (admin@alameda.com / admin123)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var resp = pm.response.json();",
                  "pm.collectionVariables.set('tokenAdmin', resp.token);",
                  "console.log('Token admin obtenido');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correoElectronico\": \"admin@alameda.com\",\n  \"contrasena\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "1.2 Autorizar correo A en whitelist",
          "request": {
