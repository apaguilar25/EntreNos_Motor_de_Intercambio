                "pm.test('Debe devolver 400 por categoria invalida', function() { pm.expect(pm.response.code).to.equal(400); });"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenAna}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idUsuario\": \"{{idAna}}\",\n  \"tipoPublicacion\": \"HABILIDAD\",\n  \"nombreServicio\": \"Clases de SURF\",\n  \"descripcion\": \"Categoria Surf no existe en habilidades.json\",\n  \"precioCreditos\": 5,\n  \"idInstanciaCatalogo\": \"h-surf-0001\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/publicaciones",
              "host": ["{{baseUrl}}"],
              "path": ["api", "publicaciones"]
