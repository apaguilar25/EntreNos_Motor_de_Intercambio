    {
      "name": "03 - Probar caché en Landing Page",
      "item": [
        {
          "name": "Landing (sin filtros) - debe usar caché",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var data = pm.response.json();",
                  "console.log('Landing: ' + data.length + ' publicaciones');",
                  "pm.test('Devuelve publicaciones', function() { pm.expect(data.length).to.be.above(0); });",
                  "pm.test('Tiempo < 100ms (cache)', function() { pm.expect(pm.response.responseTime).to.be.below(100); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/publicaciones",
              "host": ["{{baseUrl}}"],
              "path": ["api", "publicaciones"]
            }
          }
        },
        {
          "name": "Filtrado por tipo - NO usa caché",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var data = pm.response.json();",
                  "console.log('Filtradas: ' + data.length + ' publicaciones');",
                  "pm.test('Devuelve publicaciones filtradas', function() { pm.expect(data.length).to.be.above(0); });",
                  "data.forEach(function(p) { pm.expect(p.tipoPublicacion).to.equal('HABILIDAD'); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/publicaciones?tipo=HABILIDAD",
              "host": ["{{baseUrl}}"],
              "path": ["api", "publicaciones"],
              "query": [
                { "key": "tipo", "value": "HABILIDAD" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "04 - Probar invalidadción al crear/eliminar",
      "item": [
        {
          "name": "Crear nueva publicación (refresca caché)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var resp = pm.response.json();",
                  "pm.collectionVariables.set('pubNueva', resp.idPublicacion);",
                  "console.log('Nueva pub:', resp.idPublicacion);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenA}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idUsuario\": \"{{idA}}\",\n  \"tipoPublicacion\": \"HABILIDAD\",\n  \"nombreServicio\": \"Nueva publicación test\",\n  \"descripcion\": \"Creada para probar refresco de caché\",\n  \"precioCreditos\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/publicaciones",
              "host": ["{{baseUrl}}"],
              "path": ["api", "publicaciones"]
            }
          }
        },
        {
          "name": "Landing post-creación (verificar caché actualizada)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var data = pm.response.json();",
                  "console.log('Landing post-creación: ' + data.length + ' publicaciones');",
                  "pm.test('Caché incluye la nueva publicación', function() {",
                  "  var encontrada = data.some(function(p) { return p.idPublicacion === pm.collectionVariables.get('pubNueva'); });",
                  "  pm.expect(encontrada).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/publicaciones",
              "host": ["{{baseUrl}}"],
              "path": ["api", "publicaciones"]
            }
          }
        },
        {
          "name": "Eliminar publicación (refresca caché)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "console.log('Eliminada pub:', pm.collectionVariables.get('pub1'));",
                  "pm.test('Eliminación exitosa', function() { pm.expect(pm.response.code).to.equal(204); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenA}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/publicaciones/{{pub1}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "publicaciones", "{{pub1}}"]
            }
          }
        },
        {
          "name": "Landing post-eliminación (verificar caché actualizada)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var data = pm.response.json();",
                  "console.log('Landing post-eliminación: ' + data.length + ' publicaciones');",
                  "pm.test('Caché ya no incluye la publicación eliminada', function() {",
                  "  var encontrada = data.some(function(p) { return p.idPublicacion === pm.collectionVariables.get('pub1'); });",
                  "  pm.expect(encontrada).to.be.false;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/publicaciones",
              "host": ["{{baseUrl}}"],
              "path": ["api", "publicaciones"]
            }
          }
        }
      ]
    }
