    {
      "name": "08 - Invalidación de caché al crear/eliminar",
      "item": [
        {
          "name": "Crear publicación para invalidar caché",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var resp = pm.response.json();",
                "pm.collectionVariables.set('pubNuevaId', resp.idPublicacion);",
                "console.log('Nueva pub:', resp.idPublicacion);"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenAna}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idUsuario\": \"{{idAna}}\",\n  \"tipoPublicacion\": \"HABILIDAD\",\n  \"nombreServicio\": \"Test refresco cache\",\n  \"descripcion\": \"Publicacion creada para probar que la cache se actualiza\",\n  \"precioCreditos\": 1,\n  \"idInstanciaCatalogo\": \"h-cocina-0001-4000-8000-000000000001\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/publicaciones",
              "host": ["{{baseUrl}}"],
              "path": ["api", "publicaciones"]
            }
          }
        },
        {
          "name": "CON caché post-creación (caché debe incluir nueva pub)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var data = pm.response.json();",
                "var encontrada = data.some(function(p) { return p.idPublicacion === pm.collectionVariables.get('pubNuevaId'); });",
                "console.log('Nueva pub en cache:', encontrada);",
                "pm.test('Cache incluye la nueva publicacion', function() { pm.expect(encontrada).to.be.true; });"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/publicaciones",
              "host": ["{{baseUrl}}"],
              "path": ["api", "publicaciones"]
            }
          }
        },
        {
          "name": "Eliminar publicación creada",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Eliminacion exitosa 204', function() { pm.expect(pm.response.code).to.equal(204); });"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAna}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/publicaciones/{{pubNuevaId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "publicaciones", "{{pubNuevaId}}"]
            }
          }
        },
        {
          "name": "CON caché post-eliminación (caché actualizada)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var data = pm.response.json();",
                "var encontrada = data.some(function(p) { return p.idPublicacion === pm.collectionVariables.get('pubNuevaId'); });",
                "console.log('Pub eliminada en cache:', encontrada);",
                "pm.test('Cache ya NO incluye la publicacion eliminada', function() { pm.expect(encontrada).to.be.false; });"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/publicaciones",
              "host": ["{{baseUrl}}"],
              "path": ["api", "publicaciones"]
            }
          }
        }
      ]
